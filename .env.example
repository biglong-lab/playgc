# 資料庫
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/gameplatform

# 應用設定
PORT=3333
SESSION_SECRET=your_session_secret_here

# === QR Token 簽章金鑰（多元定位驗證，2026-05-22）===
# 用途：任務點 QR Code 的 HMAC-SHA256 簽章，防偽造
# 留空 = 自動 fallback 到 SESSION_SECRET（仍可運作但不建議生產用）
# 生產建議：openssl rand -hex 32 生一個獨立 secret
# 相關文件：docs/decisions/0021-multi-tier-location-verification.md
QR_TOKEN_SECRET=

# Firebase（前端用，需 VITE_ 前綴）
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Admin SDK（後端用）
FIREBASE_ADMIN_CLIENT_EMAIL=your_firebase_admin_email
FIREBASE_ADMIN_PRIVATE_KEY=your_firebase_admin_private_key

# Cloudinary（媒體上傳）
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# === Telegram Bot（內部通知）===
# 取得方式：BotFather /newbot 或 /token 取得 token
# 取得自己 chat_id：跟 bot 對話一次後 GET https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_NOTIFY_CHAT_IDS=

# === Cron Secret（系統排程觸發）===
# 用於 POST /api/cron/* endpoints
# 例：crontab 每 15 分鐘產活動結束報告
#   */15 * * * * curl -X POST https://game.homi.cc/api/cron/generate-session-reports \
#                 -H "Authorization: Bearer $CRON_SECRET"
CRON_SECRET=

# === Sentry 錯誤監控（Phase 1 / 2026-05-10、選用）===
# 取得方式：sentry.io 註冊（GitHub 登入）→ create React project → Settings → Client Keys (DSN)
# 留空 = disabled（既有 ws_event_log + reportClientEvent 仍正常運作）
# 免費 tier：5K errors/mo + 50 session replays/mo
VITE_SENTRY_DSN=
SENTRY_DSN=
# Sentry 環境（dev / production）
SENTRY_ENVIRONMENT=production
# Sentry trace 採樣率（0.0-1.0、建議 0.1 = 10%）
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Cloudflare Web Analytics（Phase 2 / 2026-05-10、選用）===
# 取得方式：CF dashboard → Web Analytics → Add a site → 拿 beacon token
# 留空 = disabled
# 完全免費、cookie-free、不影響玩家隱私
VITE_CF_BEACON_TOKEN=
